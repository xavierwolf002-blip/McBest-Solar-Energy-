# Application Configuration
APP_NAME="McBest Renewable Solar Energy"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Lagos
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_NG

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mcbest_solar
DB_USERNAME=root
DB_PASSWORD=

# Mail Configuration (for sending emails)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@mcbest.com.ng"
MAIL_FROM_NAME="${APP_NAME}"

# Admin Email (receives notifications)
ADMIN_EMAIL=admin@mcbest.com.ng
ADMIN_PHONE=+2347067823798

# Termii SMS API Configuration (Nigerian SMS Gateway)
TERMII_API_KEY=your_termii_api_key_here
TERMII_SENDER_ID=McBest
TERMII_API_URL=https://api.ng.termii.com/api

# Google reCAPTCHA v3 (Optional - for spam protection)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
RECAPTCHA_ENABLED=false

# Queue Configuration (for background jobs)
QUEUE_CONNECTION=database

# Cache Configuration (Redis recommended for production)
CACHE_DRIVER=file
CACHE_PREFIX=mcbest

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Redis Configuration (Optional but recommended)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# Filesystem Configuration
FILESYSTEM_DISK=public

# Company Information
COMPANY_NAME="McBest Renewable Solar Energy"
COMPANY_PHONE="+234 706 782 3798"
COMPANY_EMAIL="info@mcbest.com.ng"
COMPANY_ADDRESS="Plot 42, Garki District, Abuja, Nigeria"
COMPANY_WHATSAPP="2347067823798"

# Business Hours
BUSINESS_HOURS_WEEKDAY="8:00 AM - 6:00 PM"
BUSINESS_HOURS_SATURDAY="9:00 AM - 4:00 PM"
BUSINESS_HOURS_SUNDAY="Emergency Only"

# Rate Limiting
RATE_LIMIT_CALLBACK=3
RATE_LIMIT_CONTACT=5
RATE_LIMIT_NEWSLETTER=2

# Image Upload Settings
MAX_IMAGE_SIZE=2048
ALLOWED_IMAGE_TYPES=jpeg,png,jpg,webp

# SEO Configuration
SEO_TITLE="McBest | Premium Solar & Electrical Services in Nigeria"
SEO_DESCRIPTION="McBest provides premium solar panel installation, complete electrical wiring, lighting systems, and appliance services in Abuja, Nigeria. Free consultation available. 5-year warranty."
SEO_KEYWORDS="solar installation Nigeria, electrical wiring Abuja, solar panels Nigeria, inverter solutions, renewable energy Nigeria"

# Social Media Links
SOCIAL_FACEBOOK=https://facebook.com/mcbest
SOCIAL_INSTAGRAM=https://instagram.com/mcbest
SOCIAL_TIKTOK=https://tiktok.com/@mcbest
SOCIAL_WHATSAPP=https://wa.me/2347067823798

# Google Maps Coordinates
GOOGLE_MAPS_LAT=9.0765
GOOGLE_MAPS_LNG=7.3986

# Filament Admin Panel
FILAMENT_PATH=admin
FILAMENT_DOMAIN=null
